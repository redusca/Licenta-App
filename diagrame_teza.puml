' ============================================================
' 4. COMPONENT — Diagrama de componente a serverului
'    Fișier: figures/component_diagram.png
'    Referit în teză: \ref{fig:component}
' ============================================================
@startuml component_diagram
!theme plain
skinparam componentStyle rectangle

package "API Layer" {
  [FastAPI Router\n+ Uvicorn ASGI] as Router
  [Static SPA\n(React + Vite)] as SPA
}

package "Business Logic Layer" {
  [Auth Module\n(JWT / bcrypt)] as Auth
  [AI Gateway\n(BaseAIModel)] as AIGateway
  [Agent System\n(AgentPool + LangGraph)] as AgentSys
}

package "Infrastructure Layer" {
  [Redis\n(coadă + pub/sub)] as Redis
  [SQLAlchemy ORM\n+ Alembic] as ORM
}

package "External Services" {
  [Supabase\n(PostgreSQL managed)] as Supabase
  [Google Gemini API\n(gemini-2.5-flash)] as Gemini
  [HuggingFace Hub\n(Swin2SR, Whisper)] as HF
}

package "Client" {
  [FileO App\n(Docker container)] as FileO
  [Browser\n(Admin UI)] as Browser
}

FileO --> Router : REST / X-API-Key
Browser --> Router : REST / JWT
Browser --> SPA : static assets
Router --> Auth
Router --> AIGateway
Router --> AgentSys
Auth --> ORM
ORM --> Supabase
AgentSys --> Redis
AgentSys --> Gemini : LangChain
AIGateway --> HF : HuggingFace Transformers
AIGateway --> Gemini : LangChain
AgentSys --> FileO : HTTP callback POST
@enduml


' ============================================================
' 5. DEPLOYMENT — Infrastructura curentă (Mac + Supabase)
'    Fișier: figures/deploy_current.png
'    Referit în teză: \ref{fig:deploy-current}
' ============================================================
@startuml deploy_current
!theme plain
skinparam nodeStyle rectangle

node "Laptop Mac\n(uvicorn :8000)" {
  component "FastAPI Server\n(Python 3.11)" as FastAPI
  component "Redis Container\n(Docker)" as Redis
  FastAPI --> Redis : redis://localhost:6379
}

node "Supabase Cloud\n(99.9% SLA)" {
  database "PostgreSQL\n(pool via PgBouncer)" as PG
}

node "Google AI Cloud" {
  component "Gemini 2.5 Flash API" as Gemini
}

node "HuggingFace Hub" {
  component "Swin2SR weights\nWhisper Large V3 weights" as HF
  note right: descărcare la primul /wake\ncaching local ~/.cache/huggingface
}

node "Client Device" {
  component "FileO App\n(Docker container)" as FileO
}

FastAPI --> PG : DATABASE_URL (SSL :5432)
FastAPI --> Gemini : GOOGLE_API_KEY (HTTPS)
FastAPI -[dashed]-> HF : la pornire (lazy load)
FileO --> FastAPI : HTTP :8000
@enduml


