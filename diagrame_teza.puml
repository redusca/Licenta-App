' ============================================================
' 7. CLASS — Modelul de date ORM (User, AgentKey)
'    Fișier: figures/class_orm.png
'    Referit în teză: \ref{fig:class-orm}
' ============================================================
@startuml class_orm
!theme plain
skinparam classAttributeIconSize 0

class User << (E,#AADDFF) Entity >> {
  + id : UUID <<PK>>
  + email : String(255) <<unique, index>>
  + hashed_password : String(255)
  + is_active : Boolean = True
  + created_at : DateTime(tz)
  --
  + agent_key : AgentKey
  + __repr__() : str
}

class AgentKey << (E,#AADDFF) Entity >> {
  + id : UUID <<PK>>
  + user_id : UUID <<FK → users.id CASCADE>>
  + api_key : String(128) <<unique, index>>
  + created_at : DateTime(tz)
  --
  + owner : User
  + __repr__() : str
}

User "1" --o "0..1" AgentKey : agent_key\n(uselist=False) >
note bottom of User : hashed_password stochează\nexclusiv hash bcrypt;\nvaloarea clară nu e persistată.
note bottom of AgentKey : api_key = UUID generat aleator\nla înregistrare, indexat\npentru lookup rapid.
@enduml


' ============================================================
' 8. CLASS — Ierarhia modelelor AI (BaseAIModel)
'    Fișier: figures/class_ai_gateway.png
'    Referit în teză: \ref{fig:class-ai}
' ============================================================
@startuml class_ai_gateway
!theme plain
skinparam classAttributeIconSize 0

abstract class BaseAIModel {
  # _name : str
  # _model_id : str
  # _task : str
  # _is_loaded : bool
  # _device : str
  # _lock : asyncio.Lock
  --
  + name : str <<property>>
  + is_loaded : bool <<property>>
  + model_info : ModelInfo <<property>>
  + ensure_loaded() : Awaitable[None]
  + safe_unload() : Awaitable[None]
  --
  {abstract} + wake_up() : Awaitable[None]
  {abstract} + process(**kwargs) : Awaitable[Any]
  {abstract} + unload() : Awaitable[None]
}

class Swin2SRModel {
  - _processor : AutoImageProcessor
  - _model : Swin2SRForImageSuperResolution
  --
  + wake_up()
  + process(image_b64, scale) : dict
  + unload()
  - _no_ref_metrics(original, upscaled) : dict
}

class WhisperModel {
  - _model : WhisperForConditionalGeneration
  - _processor : WhisperProcessor
  - _dtype : torch.dtype
  --
  + wake_up()
  + process(audio_b64, language, expected_text) : dict
  + unload()
}

class LLMModel {
  - _llm : ChatGoogleGenerativeAI
  --
  + wake_up()
  + process(prompt, temperature, max_tokens) : dict
  + unload()
}

class VideoSubtitleModel {
  - _whisper : WhisperModel
  --
  + wake_up()
  + process(video_b64, language, fmt) : dict
  + unload()
}

BaseAIModel <|-- Swin2SRModel
BaseAIModel <|-- WhisperModel
BaseAIModel <|-- LLMModel
BaseAIModel <|-- VideoSubtitleModel
VideoSubtitleModel --> WhisperModel : delegă\ntranscrierea audio
@enduml


' ============================================================
' 9. CLASS — Sistemul de agent
'    Fișier: figures/class_agent.png
'    Referit în teză: \ref{fig:class-agent}
' ============================================================
@startuml class_agent
!theme plain
skinparam classAttributeIconSize 0

class AgentPool {
  - _redis : Redis
  - _workers : list[Task]
  + NUM_WORKERS : int = 5
  --
  + start() : Awaitable[None]
  + stop() : Awaitable[None]
  + enqueue(api_key, message, tool_definitions) : Awaitable[AgentResponse]
  - _worker(worker_id) : Awaitable[None]
}

class Session {
  - agent_executor : CompiledGraph
  - tools : list[BaseTool]
  + history : list[BaseMessage]
  --
  + reset() : None
}

class ToolDefinition << (D,#FFDDAA) Pydantic >> {
  + name : str
  + description : str
  + parameters : dict
  + callback_url : str
}

abstract class BaseBuiltinTool {
  + callback_url : str
  --
  {abstract} + execute(input: dict) : Awaitable[str]
}

class TextEditorTool {
  + execute(input: dict) : Awaitable[str]
}

class VirtualDriveMoveTool {
  + execute(input: dict) : Awaitable[str]
}

class AgentState << (T,#DDFFDD) TypedDict >> {
  + task : str
  + plan : list[str]
  + past_steps : list[tuple[str, str]]
  + response : str | None
}

AgentPool "1" --> "*" Session : gestionează\n(indexat după api_key)
Session "1" --> "*" ToolDefinition : tool-uri active
BaseBuiltinTool <|-- TextEditorTool
BaseBuiltinTool <|-- VirtualDriveMoveTool
AgentPool ..> AgentState : folosit în\nPlanning Agent
note right of AgentState
  past_steps folosește
  Annotated[list, operator.add]
  pentru acumulare LangGraph
end note
@enduml


' ============================================================
' 10. SEQUENCE — Flux autentificare JWT
'     Fișier: figures/seq_auth.png
'     Referit în teză: \ref{fig:seq-auth}
' ============================================================
@startuml seq_auth
!theme plain
skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderColor #888888

actor "Utilizator / Browser" as U
participant "FastAPI\n/api/auth" as API
participant "Auth Utils\n(bcrypt + JWT)" as Auth
database "Supabase\nPostgreSQL" as DB

== Înregistrare ==
U -> API : POST /register\n{email, password}
API -> DB : SELECT WHERE email = ?
DB --> API : null (email liber)
API -> Auth : hash_password(password)
Auth --> API : hashed_password (bcrypt)
API -> DB : INSERT User(email, hash)
DB --> API : user.id
API -> Auth : create_access_token({sub: user.id})
Auth --> API : JWT (HS256, exp=settings)
API --> U : 201 {access_token, token_type}

== Autentificare ==
U -> API : POST /login\n{username=email, password}
API -> DB : SELECT WHERE email = ?
DB --> API : user
API -> Auth : verify_password(plain, hashed)
Auth --> API : True
API -> Auth : create_access_token({sub: user.id})
Auth --> API : JWT
API --> U : 200 {access_token, token_type}

== Request protejat (GET /me) ==
U -> API : GET /me\nAuthorization: Bearer <token>
API -> Auth : decode_token(token)
Auth --> API : payload {sub: user.id}
API -> DB : SELECT WHERE id = user.id
DB --> API : user
API --> U : 200 {id, email, is_active}
@enduml


' ============================================================
' 11. SEQUENCE — Agentul conversațional ReAct
'     Fișier: figures/seq_react.png
'     Referit în teză: \ref{fig:seq-react}
' ============================================================
@startuml seq_react
!theme plain
skinparam sequenceArrowThickness 1.5

participant "FileO App" as Client
participant "FastAPI\n/api/agent/chat" as API
participant "AgentPool" as Pool
participant "Worker asyncio\n(x5)" as Worker
participant "LangGraph\n(ReAct graph)" as LG
participant "Gemini 2.5\nFlash" as Gemini
participant "FileO\ncallback_url" as Callback

Client -> API : POST /api/agent/chat\n{message, tools[], X-API-Key}
API -> API : validare X-API-Key\n(query db → AgentKey)
API -> Pool : enqueue(api_key, message, tools)
Pool -> Pool : json.dumps(payload)\nLPUSH "agent:tasks"
Pool -> Pool : SUBSCRIBE "agent:done:{task_id}"

Worker -> Worker : BRPOP "agent:tasks"
Worker -> LG : run_session(api_key, message, tools)

loop ReAct: gândire → acțiune → observație
  LG -> Gemini : invoke(history + tool_schemas)
  Gemini --> LG : AIMessage
  alt tool_call în răspuns
    LG -> Callback : POST callback_url\n{"tool": name, "input": {...}}
    Callback --> LG : {"result": "..."}
    LG -> LG : append ToolMessage(result)
  else răspuns text final
    LG --> Worker : AgentResponse
  end
end

Worker -> Pool : SET "agent:result:{task_id}" TTL=120s
Worker -> Pool : PUBLISH "agent:done:{task_id}" "1"
Pool -> Pool : GETDEL "agent:result:{task_id}"
Pool --> API : AgentResponse
API --> Client : 200 {message, tool_calls[]}
@enduml


' ============================================================
' 12. SEQUENCE — Agentul cu planificare (Plan-and-Execute)
'     Fișier: figures/seq_planning.png
'     Referit în teză: \ref{fig:seq-planning}
' ============================================================
@startuml seq_planning
!theme plain
skinparam sequenceArrowThickness 1.5

participant "FileO App" as Client
participant "FastAPI" as API
participant "AgentPool" as Pool
participant "Worker asyncio" as Worker
participant "LangGraph\nPlan-and-Execute" as LG
participant "Planner\n(Gemini)" as Planner
participant "Executor\n(Gemini + tools)" as Executor
participant "Replanner\n(Gemini)" as Replanner
participant "FileO\ncallback" as Callback

Client -> API : POST /api/agent/chat\n{message, use_planning=true, tools[]}
API -> Pool : enqueue(api_key, message, tools, use_planning=true)
Pool -> Worker : BRPOP

Worker -> LG : run_planning_session(api_key, message, tools)

LG -> Planner : invoke(AgentState{task})
Planner --> LG : plan = ["pas1", "pas2", "pas3", ...]

loop pentru fiecare pas din plan
  LG -> Executor : invoke(AgentState{plan[0], past_steps})
  Executor -> Callback : POST tool callback\n{"tool": name, "input": {...}}
  Callback --> Executor : {"result": "..."}
  Executor --> LG : (pas_curent, rezultat)

  LG -> Replanner : invoke(AgentState{task, past_steps})
  alt mai sunt pași de executat
    Replanner --> LG : AgentState{plan actualizat}
  else toate sarcinile îndeplinite
    Replanner --> LG : AgentState{response: "răspuns final"}
  end
end

LG --> Worker : AgentResponse
Worker -> Pool : SET agent:result + PUBLISH agent:done
Pool --> API : AgentResponse
API --> Client : 200 {message}
@enduml
