# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://licenta:licenta@localhost:5432/licenta

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Docker / Container Management ─────────────────────────────────────────────
# Path to Docker socket (Linux/Mac: unix:///var/run/docker.sock)
DOCKER_SOCKET=unix:///var/run/docker.sock
# Image name for the licenta-container (build from Container/docker/Dockerfile)
CONTAINER_IMAGE_NAME=licenta-container:latest
# Port the container service listens on internally
CONTAINER_INTERNAL_PORT=8001
# Docker network shared between the server and spawned agent containers.
# Set by docker-compose automatically (licenta-agents). Leave empty in bare-Docker/dev.
CONTAINER_NETWORK=

# ── GitHub (private repo releases) ──────────────────────────────────────────
# Fine-grained PAT with Contents=Read on redusca/Licenta-App
GITHUB_TOKEN=github_pat_xxxxxxxx
GITHUB_REPO=redusca/Licenta-App

# ── Google Gemini ────────────────────────────────────────────────────────────
# API key injected into server-hosted containers
GOOGLE_API_KEY=
# Model used by all containers
MODEL_NAME=gemini-2.5-flash

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for dev)
ALLOWED_ORIGINS=["*"]
