# Google Gemini API key (free tier)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Shared secret between the server and this container
# Generated automatically when the server deploys this container
# Override manually for self-hosted deployments
CONTAINER_API_KEY=change-me

# LLM model
MODEL_NAME=gemini-2.5-flash

# Max ReAct iterations before the agent gives up
MAX_ITERATIONS=10
